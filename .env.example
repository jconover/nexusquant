# Copy to .env and fill in. .env is gitignored.
# No real secrets belong in this file -- it is committed.

# Postgres / TimescaleDB
POSTGRES_USER=nexusquant
POSTGRES_PASSWORD=changeme
POSTGRES_DB=nexusquant

# MinIO
MINIO_ROOT_USER=nexusquant
MINIO_ROOT_PASSWORD=changeme

# Alpaca paper-trading (signal service, Phase 1+).
# Get real paper keys from alpaca.markets (free). The signal service starts
# with these placeholders because its settings validator only checks shape
# (non-empty, paper flag, paper URL), not key validity. Real calls to the
# /signal/{symbol} endpoint fail with an auth error until you replace them.
ALPACA_API_KEY_ID=PK_replace_me_paper_key_id
ALPACA_API_SECRET_KEY=replace_me_paper_secret_key
ALPACA_PAPER=true
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_FEED=iex
