{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexusquant.local/schemas/get_sentiment.json",
  "title": "get_sentiment",
  "description": "Optional news-sentiment score sourced from the orion Ollama enrichment sidecar.",
  "request": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "additionalProperties": false,
    "required": ["symbol"],
    "properties": {
      "symbol": { "type": "string", "pattern": "^[A-Z.]{1,10}$" },
      "lookback_hours": { "type": "integer", "minimum": 1, "maximum": 168 }
    }
  },
  "response": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "additionalProperties": false,
    "required": ["symbol", "score", "as_of"],
    "properties": {
      "symbol": { "type": "string", "pattern": "^[A-Z.]{1,10}$" },
      "score": { "type": "number", "minimum": -1, "maximum": 1 },
      "summary": { "type": "string" },
      "as_of": { "type": "string", "format": "date-time" },
      "source_count": { "type": "integer", "minimum": 0 }
    }
  }
}
